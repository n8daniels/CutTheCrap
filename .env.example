# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/cutthecrap
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# LLM Configuration
# Ollama (local LLM) - default
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# OpenAI (optional premium refinement)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# Authentication & Security
JWT_SECRET=change-this-to-a-secure-random-string-min-32-chars
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Session Management
SESSION_SECRET=change-this-to-a-secure-random-string-min-32-chars

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# API Keys for Bill Data Sources
CONGRESS_GOV_API_KEY=
PROPUBLICA_API_KEY=

# Application Settings
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Verified Author Settings
AUTHOR_VERIFICATION_REQUIRED=true

# Content Caching
ENABLE_CONTENT_CACHE=true
CACHE_TTL_HOURS=24

# Logging
LOG_LEVEL=info
