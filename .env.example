# Congress API Configuration
CONGRESS_API_KEY=your_congress_api_key_here

# FedDocMCP Configuration
FEDDOC_MCP_PATH=./packages/feddoc-mcp/src/server.py
FEDDOC_MCP_ENABLED=true

# OpenAI Configuration (for initial training and fine-tuning)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ORG_ID=your_openai_org_id_here

# CutTheCrapLLM Configuration
CUTTHECRAP_MODEL_ID=ft:gpt-4:your-org:cutthecrap:123
CUTTHECRAP_TRAINING_MODE=true

# Database (for storing training data and interactions)
DATABASE_URL=postgresql://user:password@localhost:5432/cutthecrap

# Cache Configuration (Redis)
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=86400

# Training Configuration
TRAINING_DATA_DIR=./data/training
MAX_TRAINING_EXAMPLES=100000
MIN_FEEDBACK_SCORE=4
