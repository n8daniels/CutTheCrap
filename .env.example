# OpenAI API Key (if using LLM generation)
OPENAI_API_KEY=your_api_key_here

# Congress.gov API Key (for production FedDocMCP integration)
CONGRESS_API_KEY=your_congress_api_key_here

# Model Configuration
EMBEDDING_MODEL=all-MiniLM-L6-v2
LLM_MODEL=gpt-4

# Data Paths
DATA_DIR=data/sample_documents
VECTOR_STORE_PATH=data/vector_stores

# MCP Configuration
MCP_MAX_DEPTH=2
MCP_CACHE_TTL=86400
