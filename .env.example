# Congress API Configuration
# Get your API key at: https://api.congress.gov/sign-up/
# IMPORTANT: Use DIFFERENT keys for development and production!
#
# Development: Use a separate dev key for local testing
# Production: Set production key in Vercel environment variables
#
CONGRESS_API_KEY=your_DEV_congress_api_key_here

# GovInfo API Configuration
# Get your API key at: https://api.data.gov/signup/
# Provides access to 39+ government document collections
# IMPORTANT: Use DIFFERENT keys for development and production!
#
# Development: Use a separate dev key for local testing
# Production: Set production key in Vercel environment variables
#
GOVINFO_API_KEY=your_DEV_govinfo_api_key_here

# FedDocMCP Configuration
FEDDOC_MCP_PATH=./packages/feddoc-mcp/src/server.py
FEDDOC_MCP_ENABLED=true

# Redis Configuration (optional - uses in-memory cache if not set)
REDIS_URL=redis://localhost:6379

# Environment
NODE_ENV=development

# SECURITY BEST PRACTICES:
# 1. Use separate API keys for dev, staging, and production (applies to BOTH Congress.gov and GovInfo)
# 2. Name keys clearly in API dashboards:
#    - Congress.gov: "CutTheCrap - Dev" and "CutTheCrap - Prod"
#    - GovInfo: "CutTheCrap - Dev" and "CutTheCrap - Prod"
# 3. Never commit .env files to git (already in .gitignore)
# 4. Rotate production keys every 90 days
# 5. Store production keys only in Vercel environment variables
# 6. Federal Register API requires no key (free and open)
