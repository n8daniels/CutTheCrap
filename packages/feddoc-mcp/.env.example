# Congress.gov API Configuration
# Get your free API key at: https://api.congress.gov/sign-up/
CONGRESS_API_KEY=your_congress_api_key_here

# GovInfo API Configuration (optional)
# Get your free API key at: https://api.data.gov/signup/
# Provides access to 39+ government document collections
GOVINFO_API_KEY=your_govinfo_api_key_here

# API Configuration (optional)
# Default: https://api.congress.gov/v3
CONGRESS_API_BASE_URL=https://api.congress.gov/v3

# Rate limiting (optional)
# Congress.gov allows 5000 requests per hour
# Default: 5000
CONGRESS_API_RATE_LIMIT=5000

# Logging Configuration (optional)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
LOG_LEVEL=INFO

# Cache Configuration (optional - for future use)
# Default: false
ENABLE_CACHE=false
CACHE_TTL=3600

# Development Settings (optional)
# Set to true to enable development mode features
# Default: false
DEV_MODE=false
